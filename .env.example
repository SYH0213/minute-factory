# .env.example - 이 파일을 .env 로 복사하여 사용하세요.

# OpenAI API 키 (Whisper, GPT-4)
OPENAI_API_KEY="여기에 OpenAI API 키를 입력하세요"

# Google AI API 키 (Gemini-Pro)
GOOGLE_API_KEY="여기에 Google AI API 키를 입력하세요"

# Tavily API 키 (음성 합성)
TAVILY_API_KEY="여기에 Tavily API 키를 입력하세요"

# Pyannote.audio를 위한 Hugging Face 인증 토큰
# https://huggingface.co/pyannote/speaker-diarization-3.1 에서 라이선스 동의 후
# https://huggingface.co/settings/tokens 에서 토큰을 발급받으세요. (Role: read)
PYANNOTE_TOKEN="여기에 Hugging Face 토큰을 입력하세요"

# test